{
  // Set Prettier as the default formatter for all supported files
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Enable automatic formatting whenever you save a file
  "editor.formatOnSave": true,

  // Optional: Language-specific formatting overrides
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
